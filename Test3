local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "MM2InvisFinalGui"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 160, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 16
ToggleButton.Text = "MM2 Настоящий Инвиз"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

local isInvis = false
local renderConnection = nil
local savedData = {}

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    isInvis = not isInvis
    
    if isInvis then
        ToggleButton.Text = "Выключить Инвиз"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- Прячем меши и одежду для сервера, но делаем полупрозрачными локально
        renderConnection = RunService.Heartbeat:Connect(function()
            if not isInvis or not character then return end
            
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    -- Для вас: полупрозрачный вид
                    part.Transparency = 0.5
                    part.CanCollide = false
                    
                    -- Хак для репликации сервера: убираем меш из сетевой видимости
                    local mesh = part:FindFirstChildOfClass("SpecialMesh") or part:FindFirstChildOfClass("CharacterMesh")
                    if mesh then
                        mesh.Scale = Vector3.new(0, 0, 0)
                    end
                elseif part:IsA("Decal") or part:IsA("Texture") then
                    part.Transparency = 1 -- Скрываем лицо
                elseif part:IsA("Accessory") or part:IsA("Shirt") or part:IsA("Pants") then
                    -- Локально скрываем аксессуары и одежду для полной невидимости у других
                    local handle = part:FindFirstChild("Handle")
                    if handle then handle.Transparency = 1 end
                end
            end
        end)
        
    else
        -- Отключение без смерти
        ToggleButton.Text = "MM2 Настоящий Инвиз"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        if renderConnection then
            renderConnection:Disconnect()
            renderConnection = nil
        end
        
        -- Возвращаем всё в нормальное состояние
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 0
                part.CanCollide = true
                local mesh = part:FindFirstChildOfClass("SpecialMesh") or part:FindFirstChildOfClass("CharacterMesh")
                if mesh then
                    mesh.Scale = Vector3.new(1, 1, 1)
                end
            elseif part:IsA("Decal") or part:IsA("Texture") then
                part.Transparency = 0
            elseif part:IsA("Accessory") then
                local handle = part:FindFirstChild("Handle")
                if handle then handle.Transparency = 0 end
            end
        end
    end
end)
