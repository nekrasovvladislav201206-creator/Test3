local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "UniversalPerfectLoopGui"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 180, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 14
ToggleButton.Text = "Режим: ОБЫЧНЫЙ"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

local currentMode = 0
local savedTransparencies = {}
local loopConnection = nil

-- Функция полной очистки всех эффектов перед переключением режима
local function resetAll()
    if loopConnection then loopConnection:Disconnect(); loopConnection = nil end
    
    character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local root = character.HumanoidRootPart
    
    -- Сброс физики
    root.Velocity = Vector3.new(0,0,0)
    root.RotVelocity = Vector3.new(0,0,0)
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
            part.Velocity = Vector3.new(0,0,0)
            part.RotVelocity = Vector3.new(0,0,0)
        end
    end
    
    -- Возвращаем видимость кожи и одежды
    for part, trans in pairs(savedTransparencies) do
        if part and part.Parent then
            part.Transparency = trans
        end
    end
    
    -- Возвращаем аксессуары и шляпы
    for _, access in pairs(character:GetDescendants()) do
        if access:IsA("Accessory") and access:FindFirstChild("Handle") then
            access.Handle.Transparency = 0
        end
    end
    
    table.clear(savedTransparencies)
end

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character or player.CharacterAdded:Wait()
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local root = character.HumanoidRootPart
    
    -- Переключение режимов по кругу (0 -> 1 -> 2 -> 0)
    currentMode = (currentMode + 1) % 3
    resetAll() 
    
    if currentMode == 1 then
        -- === РЕЖИМ 1: БЕССМЕРТИЕ (No-Clip Phase God) ===
        -- Вы не крутитесь, не улетаете, можете сами собирать любые вещи ногами
        ToggleButton.Text = "Режим: БЕССМЕРТИЕ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        
        loopConnection = RunService.Stepped:Connect(function()
            if character then
                -- Отключаем коллизию со всеми игроками и их оружием
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = false
                    end
                end
                -- Оставляем только HumanoidRootPart коллизию с картой, чтобы не падать сквозь пол
                if root then
                    root.CanCollide = true
                    root.Velocity = Vector3.new(root.Velocity.X, root.Velocity.Y, root.Velocity.Z)
                    root.RotVelocity = Vector3.new(0,0,0) -- Никакого вращения!
                end
            end
        end)
        
    elseif currentMode == 2 then
        -- === РЕЖИМ 2: НЕВИДИМОСТЬ (Server-Desync Invis) ===
        -- Скрипт ничего не собирает. Вы бегаете невидимкой на поверхности земли
        ToggleButton.Text = "Режим: НЕВИДИМОСТЬ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        loopConnection = RunService.Heartbeat:Connect(function()
            if character and root then
                -- Ломаем отправку координат положения частей тела на сервер
                for _, part in pairs(character:GetChildren()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        if not savedTransparencies[part] then
                            savedTransparencies[part] = part.Transparency
                        end
                        -- Локально вы себя видите полупрозрачным
                        part.Transparency = 0.5
                        
                        -- Для сервера вы застыли в одной невидимой точке
                        part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                        part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                    end
                end
                
                -- Полностью прячем аксессуары и лица для других
                for _, access in pairs(character:GetDescendants()) do
                    if access:IsA("Accessory") and access:FindFirstChild("Handle") then
                        access.Handle.Transparency = 1
                    elseif access:IsA("Decal") or access:IsA("Texture") then
                        access.Transparency = 1
                    end
                end
            end
        end)
        
    else
        -- === РЕЖИМ 0: ОБЫЧНЫЙ ===
        ToggleButton.Text = "Режим: ОБЫЧНЫЙ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end
end)
