local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "MM2InvisDelay75Gui"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 170, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 15
ToggleButton.Text = "ММ2 Идеальный Инвиз"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

local isInvis = false
local loopConnection = nil
local godConnection = nil
local savedTransparencies = {}

-- Настройка задержки подбора (0.75 секунды)
local lastTeleportTime = 0
local delayDuration = 0.75 -- Время удержания на предмете изменено на 0.75
local currentTargetItem = nil

-- Функция проверки объектов рядом с игроком
local function checkItems(rootPart)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            -- 1. Проверка монеты
            if obj.Name == "Coin_Server" then
                if (obj.Position - rootPart.Position).Magnitude < 6 then
                    return obj
                end
            end
            
            -- 2. Проверка упавшего пистолета
            if obj.Name == "HumanoidRootPart" and obj.Parent then
                local parentName = obj.Parent.Name:lower()
                if parentName:find("gun") or obj.Parent:FindFirstChild("Gun") then
                    if (obj.Position - rootPart.Position).Magnitude < 6 then -- Ошибка дистанции исправлена
                        return obj
                    end
                end
            end
        end
    end
    return nil
end

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local root = character.HumanoidRootPart
    
    isInvis = not isInvis
    
    if isInvis then
        ToggleButton.Text = "Выключить Инвиз"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- 1. Делаем себя полупрозрачным локально
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                savedTransparencies[part] = part.Transparency
                part.Transparency = 0.5
            elseif part:IsA("Decal") or part:IsA("Texture") then
                savedTransparencies[part] = part.Transparency
                part.Transparency = 0.7
            end
        end
        
        -- Годмод (Защита от ножа)
        godConnection = RunService.Stepped:Connect(function()
            if character then
                for _, plr in pairs(Players:GetPlayers()) do
                    if plr ~= player and plr.Character and plr.Character:FindFirstChild("Knife") then
                        local knife = plr.Character.Knife
                        if knife:FindFirstChild("TouchInterest") then
                            knife.TouchInterest:Destroy()
                        end
                    end
                end
            end
        end)
        
        -- 2. Главный физический цикл: скрытие суставов на сервере + задержка подбора 0.75 сек
        loopConnection = RunService.Heartbeat:Connect(function()
            if isInvis and character and root then
                local currentTime = os.clock()
                
                -- Прячем отображение суставов для других игроков
                for _, joint in pairs(character:GetDescendants()) do
                    if joint:IsA("Motor6D") and joint.Name ~= "RootJoint" then
                        joint.Transform = CFrame.new(0, -9999, 0)
                    end
                end
                
                -- Логика удержания хитбокса на предмете
                if currentTime - lastTeleportTime < delayDuration and currentTargetItem then
                    if currentTargetItem.Parent then -- Проверка, что предмет еще не исчез
                        root.CFrame = currentTargetItem.CFrame
                    else
                        currentTargetItem = nil -- Если монета подобралась раньше, сбрасываем таймер
                    end
                else
                    -- Время удержания вышло -> ищем новые предметы вокруг
                    local target = checkItems(root)
                    if target then
                        currentTargetItem = target
                        lastTeleportTime = currentTime
                        root.CFrame = target.CFrame
                    else
                        currentTargetItem = nil
                    end
                end
                root.Velocity = Vector3.new(0, 0, 0)
            end
        end)
        
    else
        -- 3. Безопасное отключение: без смерти и багов
        ToggleButton.Text = "ММ2 Идеальный Инвиз"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        if loopConnection then loopConnection:Disconnect() end
        if godConnection then godConnection:Disconnect() end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        
        -- Возвращаем видимость скину
        for part, trans in pairs(savedTransparencies) do
            if part and part.Parent then
                part.Transparency = trans
            end
        end
        savedTransparencies = {}
        currentTargetItem = nil
    end
end)
