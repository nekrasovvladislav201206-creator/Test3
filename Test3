local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "MM2InvisFinalFixGui"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 170, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 15
ToggleButton.Text = "ММ2 Инвиз + Годмод"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

local isInvis = false
local clone = nil
local loopConnection = nil
local godConnection = nil

-- Функция проверки объектов рядом с полупрозрачным клоном
local function checkItems(cloneRoot)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            -- 1. Проверка монеты
            if obj.Name == "Coin_Server" then
                if (obj.Position - cloneRoot.Position).Magnitude < 5 then
                    return obj
                end
            end
            
            -- 2. Проверка упавшего пистолета (HumanoidRootPart от пустой модельки оружия)
            if obj.Name == "HumanoidRootPart" and obj.Parent then
                local parentName = obj.Parent.Name:lower()
                if parentName:find("gun") or obj.Parent:FindFirstChild("Gun") then
                    if (obj.Position - cloneRoot.Position).Magnitude < 5 then
                        return obj
                    end
                end
            end
        end
    end
    return nil
end

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    isInvis = not isInvis
    
    if isInvis then
        ToggleButton.Text = "Выключить Хаки"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- Создаем локального полупрозрачного клона
        character.Archivable = true
        clone = character:Clone()
        clone.Parent = workspace
        
        for _, part in pairs(clone:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 0.5
                part.CanCollide = false
            elseif part:IsA("Decal") then
                part.Transparency = 0.6
            end
        end
        
        -- Направляем камеру на клона
        workspace.CurrentCamera.CameraSubject = clone:FindFirstChild("Humanoid")
        player.Character = clone
        
        -- Годмод (Локальное бессмертие от ножа)
        godConnection = RunService.Stepped:Connect(function()
            if character then
                for _, child in pairs(character:GetChildren()) do
                    if child:IsA("BasePart") then child.CanCollide = false end
                end
                
                for _, plr in pairs(Players:GetPlayers()) do
                    if plr ~= player and plr.Character and plr.Character:FindFirstChild("Knife") then
                        local knife = plr.Character.Knife
                        if knife:FindFirstChild("TouchInterest") then
                            knife.TouchInterest:Destroy()
                        end
                    end
                end
            end
        end)
        
        -- Главный цикл перемещения
        loopConnection = RunService.Heartbeat:Connect(function()
            if isInvis and character and character:FindFirstChild("HumanoidRootPart") and clone and clone:FindFirstChild("HumanoidRootPart") then
                local realRoot = character.HumanoidRootPart
                local cloneRoot = clone.HumanoidRootPart
                
                local targetItem = checkItems(cloneRoot)
                
                if targetItem then
                    -- Прыгаем оригиналом на вещь для подбора
                    realRoot.CFrame = targetItem.CFrame
                else
                    -- Сидим глубоко под землей
                    realRoot.CFrame = cloneRoot.CFrame * CFrame.new(0, -150, 0)
                end
                realRoot.Velocity = Vector3.new(0, 0, 0)
            end
        end)
        
    else
        -- Безопасный выход без смерти
        ToggleButton.Text = "ММ2 Инвиз + Годмод"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        if loopConnection then loopConnection:Disconnect() end
        if godConnection then godConnection:Disconnect() end
        
        player.Character = character
        workspace.CurrentCamera.CameraSubject = character:FindFirstChild("Humanoid")
        
        if character and character:FindFirstChild("HumanoidRootPart") and clone and clone:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.CFrame = clone.HumanoidRootPart.CFrame
        end
        
        if clone then
            clone:Destroy()
            clone = nil
        end
        
        if character then
            for _, child in pairs(character:GetChildren()) do
                if child:IsA("BasePart") then child.CanCollide = true end
            end
        end
    end
end)
