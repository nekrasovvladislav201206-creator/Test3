local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "MM2LoopHackFixedGui"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 180, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 14
ToggleButton.Text = "Режим: ОБЫЧНЫЙ"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

-- Переменные состояний (0 = обычный, 1 = бессмертие, 2 = невидимость)
local currentMode = 0
local savedTransparencies = {}
local loopConnection = nil

-- Функция полной очистки всех режимов перед переключением
local function resetAll()
    if loopConnection then loopConnection:Disconnect(); loopConnection = nil end
    
    character = player.Character
    if not character then return end
    
    -- Возвращаем физику и коллизию
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
        end
    end
    
    -- Возвращаем видимость без ресета и смерти
    for part, trans in pairs(savedTransparencies) do
        if part and part.Parent then
            part.Transparency = trans
            local mesh = part:FindFirstChildOfClass("SpecialMesh") or part:FindFirstChildOfClass("CharacterMesh")
            if mesh then mesh.Scale = Vector3.new(1, 1, 1) end
        end
    end
    
    -- Возвращаем аксессуары
    for _, access in pairs(character:GetDescendants()) do
        if access:IsA("Accessory") and access:FindFirstChild("Handle") then
            access.Handle.Transparency = 0
        end
    end
    
    table.clear(savedTransparencies)
end

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character or player.CharacterAdded:Wait()
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    -- Переключаем режим по кругу (0 -> 1 -> 2 -> 0)
    currentMode = (currentMode + 1) % 3
    resetAll() -- Сбрасываем предыдущий режим перед активацией нового
    
    if currentMode == 1 then
        -- === РЕЖИМ 1: РАБОЧЕЕ БЕССМЕРТИЕ (NoClip-God) ===
        ToggleButton.Text = "Режим: БЕССМЕРТИЕ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        
        -- Потоковый NoClip: отключает хитбокс коллизии персонажа. Нож мардера просто пролетает сквозь вас, не нанося урон
        loopConnection = RunService.Stepped:Connect(function()
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
        
    elseif currentMode == 2 then
        -- === РЕЖИМ 2: МГНОВЕННАЯ НЕВИДИМОСТЬ ===
        ToggleButton.Text = "Режим: НЕВИДИМОСТЬ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- Постоянный цикл скрытия мешей для сервера (зануление масштаба)
        loopConnection = RunService.Heartbeat:Connect(function()
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        -- Сохраняем оригинал, если еще не сохранили
                        if not savedTransparencies[part] then
                            savedTransparencies[part] = part.Transparency
                        end
                        -- Для тебя: полупрозрачный вид
                        part.Transparency = 0.5
                        part.CanCollide = false
                        
                        -- Для сервера: сжимаем части тела в ноль, игроки видят пустоту
                        local mesh = part:FindFirstChildOfClass("SpecialMesh") or part:FindFirstChildOfClass("CharacterMesh")
                        if mesh then
                            mesh.Scale = Vector3.new(0, 0, 0)
                        end
                    elseif part:IsA("Decal") or part:IsA("Texture") then
                        part.Transparency = 1
                    elseif part:IsA("Accessory") and part:FindFirstChild("Handle") then
                        part.Handle.Transparency = 1
                    end
                end
            end
        end)
        
    else
        -- === РЕЖИМ 0: ОБЫЧНЫЙ ===
        ToggleButton.Text = "Режим: ОБЫЧНЫЙ"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end
end)
