local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui
ScreenGui.Name = "MM2GhostInvisAntiStuck"

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = ScreenGui
ToggleButton.Size = UDim2.new(0, 170, 0, 50)
ToggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 15
ToggleButton.Text = "ММ2 Без лагов и застреваний"
ToggleButton.Active = true
ToggleButton.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = ToggleButton

local isInvis = false
local ghost = nil
local loopConnection = nil
local clickConnection = nil
local noclipConnection = nil

local lastActionTime = 0
local delayDuration = 0.75 -- Твоя задержка 0.75 сек
local actionCFrame = nil

-- Функция поиска монет и оружия вокруг призрака
local function checkItems(ghostRoot)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            -- 1. Поиск монеты
            if obj.Name == "Coin_Server" then
                if (obj.Position - ghostRoot.Position).Magnitude < 6 then
                    return obj
                end
            end
            
            -- 2. Поиск упавшего пистолета
            if obj.Name == "HumanoidRootPart" and obj.Parent then
                local parentName = obj.Parent.Name:lower()
                if parentName:find("gun") or obj.Parent:FindFirstChild("Gun") then
                    if (obj.Position - ghostRoot.Position).Magnitude < 6 then
                        return obj
                    end
                end
            end
        end
    end
    return nil
end

ToggleButton.MouseButton1Click:Connect(function()
    character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local realRoot = character.HumanoidRootPart
    
    isInvis = not isInvis
    
    if isInvis then
        ToggleButton.Text = "Выключить Инвиз"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        -- 1. Создаем локального полупрозрачного призрака-наводчика
        character.Archivable = true
        ghost = character:Clone()
        ghost.Parent = workspace
        
        for _, part in pairs(ghost:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 0.5
                part.CanCollide = false
            elseif part:IsA("Decal") then
                part.Transparency = 0.6
            end
        end
        
        -- Привязываем камеру к призраку
        workspace.CurrentCamera.CameraSubject = ghost:FindFirstChild("Humanoid")
        
        -- 2. Тотальный NoClip и отключение веса (чтобы не застревать в полу и гарантированно уйти вниз)
        noclipConnection = RunService.Stepped:Connect(function()
            if isInvis and character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false -- Отключаем столкновения с полом и стенами
                        part.Massless = true -- Делаем персонажа невесомым
                    end
                end
            end
        end)
        
        -- 3. Отслеживаем клики мыши для атаки/выстрела оружия
        clickConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                actionCFrame = ghost:FindFirstChild("HumanoidRootPart").CFrame
                lastActionTime = os.clock()
            end
        end)
        
        -- 4. Главный цикл физики
        loopConnection = RunService.Heartbeat:Connect(function()
            if isInvis and character and realRoot and ghost and ghost:FindFirstChild("HumanoidRootPart") do
                local currentTime = os.clock()
                local ghostRoot = ghost.HumanoidRootPart
                
                -- Синхронизируем ходьбу оригинала с призраком
                realRoot.Velocity = ghostRoot.Velocity
                
                -- Отключаем силу притяжения на оригинале, чтобы физика Roblox не тянула его в текстуры пола
                realRoot.AssemblyLinearVelocity = Vector3.new(ghostRoot.Velocity.X, 0, ghostRoot.Velocity.Z)
                
                -- Логика удержания на 0.75 сек
                if currentTime - lastActionTime < delayDuration and actionCFrame then
                    realRoot.CFrame = actionCFrame
                else
                    local targetItem = checkItems(ghostRoot)
                    if targetItem then
                        -- Прыгаем к монете (сквозь пол, без застревания благодаря NoClip)
                        actionCFrame = targetItem.CFrame
                        lastActionTime = currentTime
                        realRoot.CFrame = actionCFrame
                    else
                        -- Действий нет: уходим глубоко под землю (100% инвиз, так как пол больше не держит)
                        actionCFrame = nil
                        realRoot.CFrame = ghostRoot.CFrame * CFrame.new(0, -100, 0)
                    end
                end
            end
        end)
        
    else
        -- Безопасное выключение
        ToggleButton.Text = "ММ2 Без лагов и застреваний"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        if loopConnection then loopConnection:Disconnect() end
        if clickConnection then clickConnection:Disconnect() end
        if noclipConnection then noclipConnection:Disconnect() end
        
        workspace.CurrentCamera.CameraSubject = character:FindFirstChild("Humanoid")
        
        if character and realRoot and ghost and ghost:FindFirstChild("HumanoidRootPart") then
            -- Возвращаем наверх
            realRoot.CFrame = ghost.HumanoidRootPart.CFrame
        end
        
        -- Возвращаем коллизию обратно
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                    part.Massless = false
                end
            end
        end
        
        if ghost then
            ghost:Destroy()
            ghost = nil
        end
    end
end)
